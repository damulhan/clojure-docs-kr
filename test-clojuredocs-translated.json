          "body": ";; if vs. when\n\n;; else 분기가 없는 if...\nuser=> (if true \"then branch\")\n\"then branch\"\nuser=> (if false \"then branch\")\nnil\n\n;; ...은 when과 동일합니다.\nuser=> (when true \"then branch\")\n\"then branch\"\nuser=> (when false \"then branch\")\nnil\n\n;; else 분기가 필요하지 않은 경우에는 if 대신 when 사용을 권장합니다.",
          "_id": "5f8ea7a9e4b0b1e3652d73e6"
        }
