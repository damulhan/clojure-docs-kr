          "body": "\"\"\"\n;;함수를 변수에 할당\n\n(def say-hello\n (fn [name]\n   (str \"Hello \" name)))\n\n(say-hello \"World\")\n;;\"Hello World\"\n\n\n;;동일하지만 익명 함수 사용\n(def say-hello\n #(str \"Hello \" %))\n\n(say-hello \"World\")\n;;\"Hello World\"\n\n\n;;두 개의 인자를 사용하는 익명 함수\n(def hello-doc #(str \"Hello \" %1 %2))\n\n(hello-doc \"Dr.\" \"House\")\n;;\"Hello Dr.House\"\n\n\n\"\"\"",
          "_id": "5a86b9d4e4b0316c0f44f8c6"
